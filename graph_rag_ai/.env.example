# FinTrace Environment Configuration
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── LLM: OpenAI gpt-4o-mini (cloud inference) ──────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Neo4j AuraDB ────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# ─── NewsAPI (optional) ───────────────────────────────────────────────────────
# Get a free key at https://newsapi.org
NEWSAPI_KEY=your-newsapi-key-here

# ─── PDF Processing Configuration ────────────────────────────────────────────
PDF_PATH=pdf/document.pdf
PDF_CHUNK_SIZE=600
PDF_CHUNK_OVERLAP=90
PDF_BATCH_SIZE=5

# ─── Redis Configuration (Broker, Result Backend, Caching) ───────────────────
# Redis is used as Celery message broker, result backend, and for caching.
# Make sure Redis is running: redis-server (or via Docker)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TIMEOUT=3600
REDIS_EMBEDDING_CACHE_TTL=86400
USE_REDIS_CACHE=True

# ─── Celery Task Queue ───────────────────────────────────────────────────────
# These default to REDIS_URL if not explicitly set.
# Uncomment to override with a different Redis instance:
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── News Watcher Schedule (Celery Beat) ─────────────────────────────────────
# How often (in minutes) to scan news feeds for disruptions
NEWS_WATCHER_INTERVAL_MINUTES=60

# ─── Logging Configuration ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Advanced / Optional Configuration ──────────────────────────────────────
USE_STRUCTURED_OUTPUTS=True
GRAPH_DEPTH_LIMIT=3
