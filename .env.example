# ═══════════════════════════════════════════════════════════════════════════
# FinTrace — Agentic GraphRAG Supply Chain Monitor
# Environment Configuration Template
# 
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# CRITICAL: Django Configuration
# ───────────────────────────────────────────────────────────────────────────
# DJANGO_SECRET_KEY: Used for session/CSRF token security.
#   IMPORTANT: Generate a new random key for production!
#   Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-this-to-a-random-secret-key-in-production

# DEBUG: Enable Django debug mode (errors show in browser).
#   Set to False in production!
DEBUG=True

# ALLOWED_HOSTS: Comma-separated list of domains/IPs allowed to access the app.
#   Examples: localhost,127.0.0.1 or example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ───────────────────────────────────────────────────────────────────────────
# CRITICAL: Neo4j Database Configuration
# ───────────────────────────────────────────────────────────────────────────
# NEO4J_URI: Connection URI for Neo4j instance
#   - Aura (cloud): neo4j+s://[instance-id].databases.neo4j.io
#   - Local: neo4j://localhost:7687
#   - Docker: neo4j://neo4j:7687
# The application WILL NOT start without valid Neo4j credentials.
NEO4J_URI=neo4j+s://6fcfab01.databases.neo4j.io

# NEO4J_USER: Neo4j database username
#   For Aura: typically matches your instance ID
NEO4J_USER=neo4j

# NEO4J_PASSWORD: Neo4j database password (NEVER commit real values!)
#   For Aura: Check your instance details
#   SECURITY: Consider using secrets management in production
NEO4J_PASSWORD=your-neo4j-password-here


# ───────────────────────────────────────────────────────────────────────────
# LLM Configuration: Ollama (Local Inference, No API Key Required)
# ───────────────────────────────────────────────────────────────────────────
# Ollama provides fully local, offline LLM inference.
# Requirements:
#   1. Install Ollama: https://ollama.ai
#   2. Start Ollama server: ollama serve
#   3. Pull the model: ollama pull llama3.2

# OLLAMA_BASE_URL: URL where Ollama API is accessible
#   Default (development): http://localhost:11434
#   Docker: http://ollama:11434 (if on same network)
OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_MODEL: Model name to use for inference
#   Available models: llama3.2, llama2, mistral, neural-chat, etc.
#   Make sure to pull it first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2


# ───────────────────────────────────────────────────────────────────────────
# NewsAPI Configuration (Optional — for News Ingestion)
# ───────────────────────────────────────────────────────────────────────────
# NEWSAPI_KEY: API key for fetching supply chain news
#   Get a free key at: https://newsapi.org
#   Leave empty to disable news ingestion features
#   WARNING: Never commit real API keys to version control!
NEWSAPI_KEY=your-newsapi-key-here


# ───────────────────────────────────────────────────────────────────────────
# PDF Processing Configuration
# ───────────────────────────────────────────────────────────────────────────
# PDF_PATH: Path to the PDF file for document ingestion
#   Can be absolute or relative to project root
#   Example: /absolute/path/to/document.pdf
#   Example: pdf/NordOil_SupplyChain_Short.pdf (relative)
PDF_PATH=pdf/document.pdf

# PDF_CHUNK_SIZE: Size of text chunks (in characters) for splitting documents
#   Larger values = fewer chunks, less granularity
#   Typical range: 500-1500
PDF_CHUNK_SIZE=600

# PDF_CHUNK_OVERLAP: Character overlap between consecutive chunks
#   Preserves context between chunks for better entity extraction
#   Typical value: 10-20% of CHUNK_SIZE
PDF_CHUNK_OVERLAP=90

# PDF_BATCH_SIZE: Number of chunks to process in parallel
#   Higher values = faster processing, but more memory/API calls
#   Adjust based on available resources
PDF_BATCH_SIZE=5


# ───────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ───────────────────────────────────────────────────────────────────────────
# LOG_LEVEL: Logging verbosity
#   Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
#   Use DEBUG for development, INFO for production
LOG_LEVEL=INFO


# ───────────────────────────────────────────────────────────────────────────
# Advanced / Optional Configuration
# ───────────────────────────────────────────────────────────────────────────
# USE_STRUCTURED_OUTPUTS: Whether to use LLM structured output mode
#   Falls back to JSON parsing if unavailable
USE_STRUCTURED_OUTPUTS=True

# GRAPH_DEPTH_LIMIT: Maximum traversal depth for graph queries
#   Prevents expensive/long-running queries
#   Typical range: 2-5
GRAPH_DEPTH_LIMIT=3

# ───────────────────────────────────────────────────────────────────────────
# Redis Configuration (Caching, Task Queuing, Sessions)
# ───────────────────────────────────────────────────────────────────────────
# REDIS_URL: Connection URL for Redis instance
#   - Local: redis://localhost:6379/0
#   - Docker: redis://redis:6379/0
#   - Remote with auth: redis://:password@host:port/0
REDIS_URL=redis://localhost:6379/0

# REDIS_CACHE_TIMEOUT: Default cache timeout in seconds (1 hour)
REDIS_CACHE_TIMEOUT=3600

# REDIS_EMBEDDING_CACHE_TTL: TTL for cached embeddings in seconds (24 hours)
#   Embeddings are kept longer since they don't change
REDIS_EMBEDDING_CACHE_TTL=86400

# USE_REDIS_CACHE: Enable/disable Redis caching for PDF pipeline
#   Set to False if Redis is unavailable (caching will be skipped)
USE_REDIS_CACHE=True

